#!/bin/sh
set -e

# Determine all files that are about to be pushed. A new branch has no push
# upstream yet, so compare it with the merge-base of origin/main instead of
# checking only the latest commit.
if git rev-parse --verify '@{push}' >/dev/null 2>&1; then
  BASE='@{push}'
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
  BASE=$(git merge-base HEAD origin/main)
else
  BASE=HEAD~1
fi
CHANGED=$(git diff --name-only "$BASE"..HEAD)

# Rust: clippy
if printf '%s\n' "$CHANGED" | grep -Eq '^snapdog-ctrl/.*(\.rs$|Cargo\.(toml|lock)$)'; then
  cd snapdog-ctrl
  cargo clippy --locked --all-targets
  cargo test --locked
  cd ..
fi

if printf '%s\n' "$CHANGED" | grep -Eq '^snapdog-update/.*(\.rs$|Cargo\.(toml|lock)$)'; then
  cd snapdog-update
  cargo clippy --locked --all-targets
  cargo test --locked
  cd ..
fi

# TypeScript: build check
if printf '%s\n' "$CHANGED" | grep -q '^snapdog-ctrl/webui/'; then
  cd snapdog-ctrl/webui && npm run build && cd ../..
fi
