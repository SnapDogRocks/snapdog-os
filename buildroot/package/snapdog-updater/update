#!/bin/sh

UPDATEURL="https://update.snapdog.cc/os"
MODE=REBOOT
FORCE=0

# Find Pi version
PIVERSION=$(cat /etc/raspberrypi.version 2>/dev/null)
if [ -z "$PIVERSION" ]; then
  PIVERSION=4
fi

# Release channel
CHANNEL=$(cat /etc/snapdog-os.channel 2>/dev/null)
if [ -z "$CHANNEL" ]; then
  CHANNEL=stable
fi

for i in "$@"; do
  case $i in
    --reboot)   MODE=REBOOT ;;
    --simulate) MODE=SIMULATE ;;
    --check)    MODE=CHECK ;;
    --force)    FORCE=1 ;;
    --beta)     CHANNEL=beta ;;
    --stable)   CHANNEL=stable ;;
    *)          CHANNEL=$i ;;
  esac
done

# Current version
MYVERSION=$(cat /etc/snapdog-os.version 2>/dev/null)
if [ -z "$MYVERSION" ]; then
  MYVERSION="0.0.0"
fi

# Fetch metadata
METADATA=$(curl -f -s -m 10 "$UPDATEURL/metadata/$CHANNEL/pi${PIVERSION}.json")
if [ "$?" != 0 ]; then
  echo "Couldn't reach update server, aborting..."
  exit 1
fi

VERSION=$(echo "$METADATA" | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
IMAGEURL=$(echo "$METADATA" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
CHECKSUM=$(echo "$METADATA" | sed -n 's/.*"sha256"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

if [ -z "$VERSION" ]; then
  echo "No update available"
  exit 0
fi

# Strict SemVer/date-version comparison (major.minor.patch, missing parts are 0)
version_gt() {
  A=$1
  B=$2
  OLDIFS=$IFS
  IFS=.
  set -- $A
  A1=${1:-0}; A2=${2:-0}; A3=${3:-0}
  set -- $B
  B1=${1:-0}; B2=${2:-0}; B3=${3:-0}
  IFS=$OLDIFS

  [ "$A1" -gt "$B1" ] && return 0
  [ "$A1" -lt "$B1" ] && return 1
  [ "$A2" -gt "$B2" ] && return 0
  [ "$A2" -lt "$B2" ] && return 1
  [ "$A3" -gt "$B3" ]
}

if [ "$FORCE" != "1" ] && ! version_gt "$VERSION" "$MYVERSION"; then
  if [ "$MODE" = "CHECK" ]; then
    exit 0
  fi
  echo "Already on latest version ($MYVERSION)"
  exit 0
fi

if [ "$MODE" = "CHECK" ]; then
  echo "Update available: $MYVERSION -> $VERSION"
  exit 0
fi

echo "Updating from $MYVERSION to $VERSION..."
echo "Downloading $IMAGEURL..."

cd /data
curl -f "$IMAGEURL" --progress-bar -o updater.tar.gz
if [ "$?" != "0" ]; then
  echo "Download failed, aborting"
  exit 1
fi

# Verify SHA256 checksum
if [ -n "$CHECKSUM" ]; then
  echo "Verifying download integrity..."
  ACTUAL=$(sha256sum /data/updater.tar.gz | awk '{print $1}')
  if [ "$ACTUAL" != "$CHECKSUM" ]; then
    echo "CHECKSUM MISMATCH! Expected: $CHECKSUM Got: $ACTUAL"
    rm -f /data/updater.tar.gz
    exit 1
  fi
  echo "Checksum verified OK"
fi

# Set boot attempt counter (rollback protection)
mount -o remount,rw /boot
echo "3" > /boot/boot-attempts
sync

# Extract and apply update
if [ "$MODE" = "REBOOT" ]; then
  /opt/snapdog/bin/extract-update --reboot
elif [ "$MODE" = "SIMULATE" ]; then
  /opt/snapdog/bin/extract-update --simulate
fi
