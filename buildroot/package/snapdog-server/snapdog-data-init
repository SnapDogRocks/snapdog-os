#!/bin/sh
# Initialize /data partition with default config files.
# Runs on first boot after /data is mounted.
# Symlinks from /etc → /data are already baked into the image (post-build.sh).

set -eu

DATA=/data

# Create directory structure
mkdir -p "$DATA/default"
mkdir -p "$DATA/snapdog"
mkdir -p "$DATA/wpa_supplicant"
mkdir -p "$DATA/hostapd"
mkdir -p "$DATA/systemd/network"
mkdir -p "$DATA/systemd/resolved.conf.d"
mkdir -p "$DATA/systemd/system/updater.timer.d"
mkdir -p "$DATA/ssh"

# Write defaults if not already present
[ -f "$DATA/default/snapdog-client" ] || echo 'SNAPDOG_CLIENT_ARGS=""' > "$DATA/default/snapdog-client"
if [ ! -f "$DATA/snapdog-os.channel" ]; then
  if grep -q "beta" /etc/snapdog-os.version 2>/dev/null; then
    echo "beta" > "$DATA/snapdog-os.channel"
  else
    echo "stable" > "$DATA/snapdog-os.channel"
  fi
fi
[ -f "$DATA/snapdog-os.auto-update" ] || printf 'enabled=true\ninterval=daily\ntime=03:00\n' > "$DATA/snapdog-os.auto-update"
[ -f "$DATA/hostname" ] || echo "snapdog" > "$DATA/hostname"

# Default wired networking: DHCP on any ethernet interface (end0 on Pi4, eth0 on
# Pi3, enx* USB adapters). Seeded here — before systemd-networkd starts — so the
# device gets an IP on first boot independently of snapdog-ctrl. snapdog-ctrl may
# overwrite this file later when a static IP is configured.
if [ ! -f "$DATA/systemd/network/10-ethernet.network" ]; then
  cat > "$DATA/systemd/network/10-ethernet.network" <<'EOF'
[Match]
Name=en* eth*

[Network]
DHCP=yes
EOF
fi
