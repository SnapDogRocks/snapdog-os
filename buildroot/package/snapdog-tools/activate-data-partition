#!/bin/sh
# Mount the data partition (LABEL=data) after resize-data-partition has formatted it.
set -eu

mkdir -p /data

# Try mounting by label first (set by resize-data-partition)
if mount -L data /data 2>/dev/null; then
  echo "Mounted data partition by label"
  exit 0
fi

# Fallback: detect device and try partition 4
ROOT=$(mount | grep " / " | awk '{print $1}')
# Strip trailing partition number to get base (works for mmcblk0p2, nvme0n1p2, sda2)
P4="${ROOT%[0-9]}4"

if [ -b "$P4" ]; then
  # Format if no filesystem
  if ! blkid "$P4" | grep -q "TYPE="; then
    mkfs.ext4 -F -L data "$P4"
  fi
  mount "$P4" /data
  echo "Mounted $P4 on /data"
else
  echo "No data partition found"
  exit 1
fi
