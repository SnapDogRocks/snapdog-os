config BR2_PACKAGE_SNAPDOG_OS_ALL
	bool "snapdog-os-all"
	help
	  Select all packages required for SnapDog OS.
	select BR2_PACKAGE_OPENSSH
	select BR2_PACKAGE_SNAPDOG_BASE
	select BR2_PACKAGE_SNAPDOG_USERS
	select BR2_PACKAGE_SNAPDOG_TOOLS
	select BR2_PACKAGE_COPY_OVERLAYS if BR2_PACKAGE_RPI_FIRMWARE
	select BR2_PACKAGE_CONFIGTXT if BR2_PACKAGE_RPI_FIRMWARE
	select BR2_PACKAGE_CONFIGTXT_QUIET if BR2_PACKAGE_RPI_FIRMWARE
	select BR2_PACKAGE_CONFIGTXT_EEPROM if BR2_PACKAGE_RPI_FIRMWARE
	select BR2_PACKAGE_RASPI_WIFI if BR2_PACKAGE_RPI_FIRMWARE
	select BR2_PACKAGE_SNAPDOG_CLIENT
	select BR2_PACKAGE_SNAPDOG_SERVER
	select BR2_PACKAGE_SNAPDOG_RAUC
	select BR2_PACKAGE_SNAPDOG_CTRL
