#!/bin/sh

if [ -f /data/updater.zip ]; then
  UPDATER=/data/updater.zip
  ISTAR=0
else
  UPDATER=/data/updater.tar.gz
  ISTAR=1
fi

if [ ! -f "$UPDATER" ]; then
  echo "$UPDATER does not exist, aborting"
  exit 1
fi

detect_rootfs_entry() {
  if [ "$ISTAR" = "1" ]; then
    tar tzf "$UPDATER" | awk '/^rootfs\.(ext4|ext2|f2fs)$/ {print; exit}'
  else
    unzip -l "$UPDATER" | awk '/rootfs\.(ext4|ext2|f2fs)$/ {print $4; exit}'
  fi
}

ROOTFS_ENTRY=$(detect_rootfs_entry)
if [ -z "$ROOTFS_ENTRY" ]; then
  echo "Could not find rootfs.ext4, rootfs.ext2, or rootfs.f2fs in $UPDATER"
  exit 1
fi
FSTYPE=${ROOTFS_ENTRY#rootfs.}

mount -o remount,rw /boot
if [ ! -f /boot/cmdline.txt ]; then
  echo "can't write to /boot/cmdline.txt, aborting"
  mount -o remount,ro /boot
  exit 1
fi

SCRIPT_DIR=$(dirname "$0")
INACTIVE=$("$SCRIPT_DIR/partitions" | awk '{print $2}')
if [ -z "$INACTIVE" ]; then
  echo "Could not determine inactive root partition, aborting"
  exit 1
fi

echo "unmounting $INACTIVE..."
umount /newroot 2>/dev/null || true

echo "extracting $ROOTFS_ENTRY to $INACTIVE..."
if [ "$ISTAR" = "1" ]; then
  gunzip -c "$UPDATER" | tar xOf - "$ROOTFS_ENTRY" | dd of="$INACTIVE" bs=1048576
else
  unzip -p "$UPDATER" "$ROOTFS_ENTRY" | dd of="$INACTIVE" bs=1048576
fi

echo "resizing new root file system..."
case "$FSTYPE" in
  ext2|ext4)
    resize2fs "$INACTIVE"
    ;;
  f2fs)
    resize.f2fs "$INACTIVE"
    ;;
  *)
    echo "Unsupported root filesystem: $FSTYPE"
    exit 1
    ;;
esac

echo "mounting new root file system..."
mkdir -p /newroot
mount "$INACTIVE" /newroot
if [ -f /newroot/resize-me ]; then
  rm /newroot/resize-me
fi
VERSION=$(cat /newroot/etc/snapdog-os.version 2>/dev/null || echo unknown)

KERNELIMAGE=zImage
if [ -f /newroot/usr/lib/firmware/rpi/Image ]; then
  KERNELIMAGE=Image
fi

echo "extracting new kernel..."
if [ -f "/newroot/usr/lib/firmware/rpi/$KERNELIMAGE" ]; then
  echo "Using $KERNELIMAGE from new RPI firmware"
  cp "/boot/$KERNELIMAGE" "/boot/$KERNELIMAGE.bak"
  cp -rv /newroot/usr/lib/firmware/rpi/* /boot
else
  cd /tmp || exit 1
  if [ "$ISTAR" = "1" ]; then
    gunzip -c "$UPDATER" | tar xf - "$KERNELIMAGE" updater.sh updater2.sh
  else
    unzip "$UPDATER" "$KERNELIMAGE" updater.sh updater2.sh
  fi
  if [ ! -f "$KERNELIMAGE" ]; then
    echo "Could not find new kernel, aborting ..."
    exit 1
  fi
  cp "/boot/$KERNELIMAGE" "/boot/$KERNELIMAGE.bak"
  mv "$KERNELIMAGE" "/boot/$KERNELIMAGE" 2>/dev/null
fi

echo "migrating SSH host keys..."
cp /etc/ssh/ssh_host* /newroot/etc/ssh 2>/dev/null || true

echo "migrating other configurations..."
CONFIG_LIST=/newroot/opt/snapdog/etc/config-files
if [ -f "$CONFIG_LIST" ]; then
  while IFS= read -r item; do
    [ -z "$item" ] && continue
    [ -e "$item" ] || continue

    dest_parent="/newroot$(dirname "$item")"
    mkdir -p "$dest_parent"
    echo "$item"
    cp -a "$item" "$dest_parent/"
  done < "$CONFIG_LIST"
fi

echo "changing files on FAT partition..."
if [ -d /newroot/boot ]; then
  (cd /newroot/boot && tar cf - .) | (cd /boot && tar xvf -)
fi

SERVICES_LIST=/newroot/opt/snapdog/etc/services
if [ -f "$SERVICES_LIST" ]; then
  echo "checking systemd services..."
  while IFS= read -r service; do
    [ -z "$service" ] && continue
    if systemctl is-enabled --quiet "$service"; then
      echo "$service: enabled"
      systemctl --root=/newroot enable "$service" >/dev/null 2>&1 || true
    else
      echo "$service: disabled"
      systemctl --root=/newroot disable "$service" >/dev/null 2>&1 || true
    fi
  done < "$SERVICES_LIST"
fi

echo "looking for update script..."
if [ -f /newroot/tmp/updater.sh ]; then
  cp /newroot/tmp/updater.sh /tmp/updater.sh
elif [ -f /newroot/updater.sh ]; then
  cp /newroot/updater.sh /tmp/updater.sh
fi
cd /tmp || exit 1
if [ ! -f updater.sh ]; then
  echo "no post-config update script found, continuing..."
else
  echo "starting upgrade script..."
  chmod +x ./updater.sh
  ./updater.sh
fi

echo "storing version number of previous release..."
cp /etc/snapdog-os.version /newroot/etc/snapdog-os.version.previous 2>/dev/null || true
sync

echo "unmounting $INACTIVE..."
umount /newroot
case "$FSTYPE" in
  ext2|ext4)
    fsck.ext2 -p -f -v "$INACTIVE"
    RES=$?
    ;;
  f2fs)
    fsck.f2fs -a "$INACTIVE"
    RES=$?
    ;;
esac
if [ "$RES" != "0" ] && [ "$RES" != "1" ]; then
  echo "file system is corrupted, not switching to new version..."
  mount -o remount,ro /boot
  exit 1
fi

if [ "$1" = "--simulate" ]; then
  echo "not switching to new version..."
  mount -o remount,ro /boot
  exit 0
fi

echo "switching root file system to inactive partition..."
echo "was:      $(cat /boot/cmdline.txt)"
CMDLINE=$(sed "s#root=[^ ]*#root=$INACTIVE#" /boot/cmdline.txt)
echo "becomes:  $CMDLINE"
echo "$CMDLINE" > /boot/cmdline.txt

if [ "$1" = "--reboot" ]; then
  echo "removing updater..."
  rm -f "$UPDATER"
  echo "rebooting..."
  sync
  reboot
else
  echo "Version $VERSION installed. You need to reboot to activate it"
  sync
  mount -o remount,ro /boot
fi
