[system]
compatible=snapdog-os-@SNAPDOG_BOARD@
bootloader=custom
statusfile=/data/rauc.status
bundle-formats=verity
# URL-based OTA installs (BR2_PACKAGE_RAUC_NETWORK) download the whole bundle; RAUC
# aborts with "Maximum file size exceeded" once it passes this cap. Without it the
# default is far below an OS bundle (~63 MiB and growing), so online updates fail
# at download. 1 GiB leaves ample headroom.
max-bundle-download-size=1073741824

[handlers]
bootloader-custom-backend=/usr/lib/rauc/boot-handler.sh

[keyring]
path=/etc/rauc/ca.cert.pem

[slot.rootfs.0]
device=@SNAPDOG_ROOT_DEV@2
type=raw
bootname=A

[slot.rootfs.1]
device=@SNAPDOG_ROOT_DEV@3
type=raw
bootname=B
