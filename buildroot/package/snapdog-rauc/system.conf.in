[system]
compatible=snapdog-os-@SNAPDOG_BOARD@
bootloader=custom
statusfile=/data/rauc.status
bundle-formats=verity
# Retain enough headroom for RAUC tooling or externally triggered URL installs.
# snapdog-ctrl's normal WebUI/automatic path stages the bundle locally so it can
# expose byte progress before invoking RAUC. 1 GiB covers either path.
max-bundle-download-size=1073741824

[handlers]
bootloader-custom-backend=/usr/lib/rauc/boot-handler.sh

[keyring]
path=/etc/rauc/ca.cert.pem

[slot.rootfs.0]
device=@SNAPDOG_ROOT_DEV@2
type=raw
bootname=A

[slot.rootfs.1]
device=@SNAPDOG_ROOT_DEV@3
type=raw
bootname=B
