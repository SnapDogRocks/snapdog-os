#!/bin/sh

set -eu

UPDATEURL="https://update.snapdog.cc/os"
PUBKEY="/etc/snapdog-os-update.pub.pem"
MODE=REBOOT
FORCE=0

die() {
  echo "$*" >&2
  exit 1
}

is_uint() {
  case "${1:-}" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

num_or_zero() {
  if is_uint "${1:-}"; then
    echo "$1"
  else
    echo 0
  fi
}

compare_identifier() {
  A=$1
  B=$2

  if is_uint "$A" && is_uint "$B"; then
    [ "$A" -gt "$B" ] && echo 1 && return
    [ "$A" -lt "$B" ] && echo -1 && return
    echo 0
    return
  fi

  if is_uint "$A"; then
    echo -1
    return
  fi
  if is_uint "$B"; then
    echo 1
    return
  fi

  [ "$A" = "$B" ] && echo 0 && return
  if [ "$A" \> "$B" ]; then
    echo 1
  else
    echo -1
  fi
}

compare_prerelease() {
  A_PRE=$1
  B_PRE=$2

  while :; do
    [ -z "$A_PRE" ] && [ -z "$B_PRE" ] && echo 0 && return
    [ -z "$A_PRE" ] && echo -1 && return
    [ -z "$B_PRE" ] && echo 1 && return

    A_ID=${A_PRE%%.*}
    B_ID=${B_PRE%%.*}
    CMP=$(compare_identifier "$A_ID" "$B_ID")
    [ "$CMP" != "0" ] && echo "$CMP" && return

    if [ "$A_ID" = "$A_PRE" ]; then A_PRE=; else A_PRE=${A_PRE#*.}; fi
    if [ "$B_ID" = "$B_PRE" ]; then B_PRE=; else B_PRE=${B_PRE#*.}; fi
  done
}

version_compare() {
  A=${1#v}
  B=${2#v}

  A_CORE=${A%%-*}
  B_CORE=${B%%-*}
  if [ "$A_CORE" = "$A" ]; then A_PRE=; else A_PRE=${A#*-}; fi
  if [ "$B_CORE" = "$B" ]; then B_PRE=; else B_PRE=${B#*-}; fi

  OLDIFS=$IFS
  IFS=.
  set -- $A_CORE
  A1=$(num_or_zero "${1:-0}"); A2=$(num_or_zero "${2:-0}"); A3=$(num_or_zero "${3:-0}")
  set -- $B_CORE
  B1=$(num_or_zero "${1:-0}"); B2=$(num_or_zero "${2:-0}"); B3=$(num_or_zero "${3:-0}")
  IFS=$OLDIFS

  [ "$A1" -gt "$B1" ] && echo 1 && return
  [ "$A1" -lt "$B1" ] && echo -1 && return
  [ "$A2" -gt "$B2" ] && echo 1 && return
  [ "$A2" -lt "$B2" ] && echo -1 && return
  [ "$A3" -gt "$B3" ] && echo 1 && return
  [ "$A3" -lt "$B3" ] && echo -1 && return

  [ -z "$A_PRE" ] && [ -z "$B_PRE" ] && echo 0 && return
  [ -z "$A_PRE" ] && echo 1 && return
  [ -z "$B_PRE" ] && echo -1 && return
  compare_prerelease "$A_PRE" "$B_PRE"
}

version_gt() {
  [ "$(version_compare "$1" "$2")" = "1" ]
}

json_string() {
  echo "$METADATA" | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p"
}

validate_channel() {
  [ "$1" = "stable" ] || [ "$1" = "beta" ]
}

# Find Pi version
PIVERSION=$(cat /etc/raspberrypi.version 2>/dev/null || true)
if [ -z "$PIVERSION" ]; then
  PIVERSION=4
fi

# Release channel
CHANNEL=$(cat /etc/snapdog-os.channel 2>/dev/null || true)
if [ -z "$CHANNEL" ]; then
  CHANNEL=stable
fi

for i in "$@"; do
  case $i in
    --reboot)   MODE=REBOOT ;;
    --simulate) MODE=SIMULATE ;;
    --check)    MODE=CHECK ;;
    --force)    FORCE=1 ;;
    --beta)     CHANNEL=beta ;;
    --stable)   CHANNEL=stable ;;
    *)          die "Unknown update option: $i" ;;
  esac
done

validate_channel "$CHANNEL" || die "Invalid update channel: $CHANNEL"

# Current version
MYVERSION=$(cat /etc/snapdog-os.version 2>/dev/null || true)
if [ -z "$MYVERSION" ]; then
  MYVERSION="0.0.0"
fi

mkdir -p /data
METADATA_FILE=/data/update-metadata.json
SIGNATURE_FILE=/data/update-metadata.json.sig
METADATA_URL="$UPDATEURL/metadata/$CHANNEL/pi${PIVERSION}.json"

curl -f -s -m 10 "$METADATA_URL" -o "$METADATA_FILE" \
  || die "Couldn't reach update server, aborting..."
curl -f -s -m 10 "$METADATA_URL.sig" -o "$SIGNATURE_FILE" \
  || die "Couldn't fetch update metadata signature, aborting..."

[ -s "$PUBKEY" ] || die "Missing update signing public key: $PUBKEY"
openssl dgst -sha256 -verify "$PUBKEY" -signature "$SIGNATURE_FILE" "$METADATA_FILE" >/dev/null \
  || die "Update metadata signature verification failed"

METADATA=$(tr -d '\n' < "$METADATA_FILE")
VERSION=$(json_string version)
IMAGEURL=$(json_string url)
CHECKSUM=$(json_string sha256)
rm -f "$METADATA_FILE" "$SIGNATURE_FILE"

if [ -z "$VERSION" ]; then
  echo "No update available"
  exit 0
fi

[ -n "$IMAGEURL" ] || die "Update metadata is missing url"
[ -n "$CHECKSUM" ] || die "Update metadata is missing sha256"
[ "${#CHECKSUM}" -eq 64 ] || die "Update checksum must be a SHA256 hex digest"
case "$CHECKSUM" in
  *[!0123456789abcdefABCDEF]*) die "Update checksum must be a SHA256 hex digest" ;;
esac
case "$IMAGEURL" in
  "$UPDATEURL"/updates/snapdog-os-pi"$PIVERSION"-*-update.tar.gz) ;;
  *) die "Update URL is outside the trusted update path: $IMAGEURL" ;;
esac

if [ "$FORCE" != "1" ] && ! version_gt "$VERSION" "$MYVERSION"; then
  if [ "$MODE" = "CHECK" ]; then
    exit 0
  fi
  echo "Already on latest version ($MYVERSION)"
  exit 0
fi

if [ "$MODE" = "CHECK" ]; then
  echo "Update available: $MYVERSION -> $VERSION"
  exit 0
fi

echo "Updating from $MYVERSION to $VERSION..."
echo "Downloading $IMAGEURL..."

cd /data
rm -f updater.tar.gz.part
curl -f "$IMAGEURL" --progress-bar -o updater.tar.gz.part

echo "Verifying download integrity..."
ACTUAL=$(sha256sum /data/updater.tar.gz.part | awk '{print $1}')
if [ "$ACTUAL" != "$CHECKSUM" ]; then
  echo "CHECKSUM MISMATCH! Expected: $CHECKSUM Got: $ACTUAL"
  rm -f /data/updater.tar.gz.part
  exit 1
fi
mv /data/updater.tar.gz.part /data/updater.tar.gz
echo "Checksum verified OK"

# Set boot attempt counter (rollback protection)
mount -o remount,rw /boot
echo "3" > /boot/boot-attempts
sync

# Extract and apply update
if [ "$MODE" = "REBOOT" ]; then
  /opt/snapdog/bin/extract-update --reboot
elif [ "$MODE" = "SIMULATE" ]; then
  /opt/snapdog/bin/extract-update --simulate
fi
